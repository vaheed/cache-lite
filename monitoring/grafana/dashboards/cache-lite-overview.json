      "type": "timeseries",
      "title": "Nginx Requests/sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(nginx_http_requests_total[1m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Nginx 5xx/sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(nginx_http_requests_total{status=~\"5..\"}[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Active Connections",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "nginx_connections_active", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Host CPU %",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Memory Used %",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Docker Registry CPU (sum)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"registry-.*\"}[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}
    },
